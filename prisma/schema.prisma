generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(nanoid())
  name      String    @unique
  pinHash   String    @unique
  pinSalt   String
  createdAt DateTime  @default(now())
  Session   Session[]
  todos     Todo[]
}

model Todo {
  id        Int      @id @default(autoincrement())
  task      String
  completed Boolean  @default(false)
  userName  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userName], references: [name], onDelete: Cascade)
}

model Hwork {
  id      String   @id @default(cuid())
  title   String
  image   String?
  subject String
  date    DateTime
  images  String[] @default([])
}

model DutySchedule {
  id        String   @id @default(nanoid())
  date      DateTime @unique
  names     String[] @default([])
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model Timetable {
  id           String   @id @default(nanoid())
  day          Day
  lessonNumber Int
  subject      String
  createdAt    DateTime @default(now())

  @@unique([day, lessonNumber])
}

model Session {
  token     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}
