generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Authentication & User ---
model User {
  id   String @id @default(nanoid())
  name String @unique

  // Security fields for your hashPin function
  pinSalt String
  pinHash String @unique

  createdAt DateTime  @default(now())
  sessions  Session[]
  todos     Todo[]
}

// Keep your Session and Todo models as they were...

model Session {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

// --- Features ---

model Todo {
  id        Int     @id @default(autoincrement())
  task      String
  completed Boolean @default(false)

  // Foreign Key linking to User.name
  userName String
  user     User   @relation(fields: [userName], references: [name], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Hwork {
  id      String   @id @default(cuid())
  subject String
  title   String
  date    DateTime
  images  String[] @default([])
  image   String?
}

model DutySchedule {
  id        String   @id @default(nanoid())
  date      DateTime @unique
  names     String[] @default([])
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model Timetable {
  id           String   @id @default(nanoid())
  day          Day
  lessonNumber Int
  subject      String
  createdAt    DateTime @default(now())

  @@unique([day, lessonNumber])
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}
