generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(nanoid())
  name      String    @unique
  pinHash   String    @unique
  pinSalt   String
  avatar    String?
  bio       String?
  instagram String?
  createdAt DateTime  @default(now())
  Session   Session[]
  todos     Todo[]
  likes     Like[]
  comments  Comment[]
}

model Todo {
  id        Int      @id @default(autoincrement())
  task      String
  completed Boolean  @default(false)
  userName  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userName], references: [name], onDelete: Cascade)
}

model Hwork {
  id      String   @id @default(cuid())
  title   String
  image   String?
  subject String
  date    DateTime
  images  String[] @default([])
}

model DutySchedule {
  id        String   @id @default(nanoid())
  date      DateTime @unique
  names     String[] @default([])
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model Timetable {
  id           String   @id @default(nanoid())
  day          Day
  lessonNumber Int
  subject      String
  createdAt    DateTime @default(now())

  @@unique([day, lessonNumber])
}

model Session {
  token     String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

// --- Chat ---
model ChatMessage {
  id        String   @id @default(nanoid())
  userName  String
  text      String
  replyToId String?
  reaction  String[] @default([])
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// --- News/Photo Feed ---
model Post {
  id        String    @id @default(nanoid())
  userName  String
  text      String
  images    String[]  @default([])
  createdAt DateTime  @default(now())
  likes     Like[]
  comments  Comment[]

  @@index([createdAt])
}

model Like {
  id       String @id @default(nanoid())
  postId   String
  userName String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userName], references: [name], onDelete: Cascade)

  @@unique([postId, userName])
}

model Comment {
  id        String   @id @default(nanoid())
  postId    String
  userName  String
  text      String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userName], references: [name], onDelete: Cascade)

  @@index([postId, createdAt])
}

enum Day {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}
